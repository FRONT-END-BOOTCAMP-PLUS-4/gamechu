{
    "env": {
        "MAX_THINKING_TOKENS": "10000"
    },
    "permissions": {
        "allow": [
            "Edit:*",
            "Write:*",
            "MultiEdit:*",
            "NotebookEdit:*",
            "Bash:*"
        ],
        "defaultMode": "acceptEdits"
    },
    "enabledMcpjsonServers": ["sequential-thinking", "playwright"],
    "hooks": {
        "UserPromptSubmit": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/skill-activation-prompt.sh"
                    }
                ]
            }
        ],
        "PreToolUse": [
            {
                "matcher": "Read",
                "hooks": [
                    {
                        "type": "command",
                        "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre-tool-use-env-guard.sh"
                    }
                ]
            }
        ],
        "PostToolUse": [
            {
                "matcher": "Edit|MultiEdit|Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post-tool-use-tracker.sh"
                    }
                ]
            }
        ],
        "Stop": [
            {
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "powershell -WindowStyle Hidden -ExecutionPolicy Bypass -File \"$CLAUDE_PROJECT_DIR/.claude/hooks/notify-stop.ps1\""
                    }
                ]
            }
        ],
        "Notification": [
            {
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "powershell -WindowStyle Hidden -ExecutionPolicy Bypass -File \"$CLAUDE_PROJECT_DIR/.claude/hooks/notify-attention.ps1\""
                    }
                ]
            }
        ]
    },
    "enabledPlugins": {
        "superpowers@claude-plugins-official": false,
        "frontend-design@claude-plugins-official": true,
        "everything-claude-code@everything-claude-code": true
    }
}
